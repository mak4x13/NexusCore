# ============================================================
# ROOT — Build output, screenshots, generated/lock files
# ============================================================

# Build output (regenerated by `vite build`)
# dist/

# Screenshots — UI documentation images, not source code
screenshots/

# npm lockfile — project uses pnpm, this is redundant
package-lock.json

# Generated default theme file (not your custom code)
default_shadcn_theme.css

# ============================================================
# DEPENDENCIES — Installed packages (regenerated by pnpm install)
# ============================================================
node_modules/

# ============================================================
# src/imports/ — Figma paste artifacts, not real source
# ============================================================

# Pasted image from Figma export (binary asset, not code)
# src/imports/image.png

# ============================================================
# src/styles/ — Redundant/overlapping CSS files
# ============================================================

# index.css is likely a duplicate or unused entry — 
# globals.css + tailwind.css + theme.css cover all styling
# src/styles/index.css

# ============================================================
# ENVIRONMENT & SECRETS
# ============================================================
.env
.env.local
.env.*.local

# ============================================================
# EDITOR / OS JUNK
# ============================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ============================================================
# LOGS
# ============================================================
*.log
npm-debug.log*
