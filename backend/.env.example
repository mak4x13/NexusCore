# Copy to .env (in backend/ and agents/ as needed). Never commit the real .env.

# Master, Proposer, and Compliance brains — GPT models via AI/ML API
AIML_API_KEY=your-aiml-key

# Risk brain — Qwen via Featherless (open-source model endpoint)
FEATHERLESS_API_KEY=your-featherless-key

# Optional: backend live Band bridge. If omitted, backend reads agents/room.txt.
BAND_ROOM=your-band-room-uuid

# Optional demo auth for public deployment. If set, write endpoints
# (/api/band/trigger, /api/actions/propose, /api/actions/{id}/decide, /api/messages)
# require header X-Demo-Token. Leave unset for local hackathon use.
DEMO_TOKEN=

# Band agent UUIDs/API keys are stored in agents/agent_config.yaml.
# Core MVP uses 4 Band agents; expanded architecture supports 9.
# Copy agents/agent_config.example.yaml and never commit real Band keys.
